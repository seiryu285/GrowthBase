# Demo-safe environment variables for public GitHub repository.

# Copy this file to .env.local for local development.
# For live mode, keep fail-closed enabled and prefer explicit event/market slug targeting over broad auto discovery.

# Never commit private keys, mnemonics, API secrets, or production credentials.



DATABASE_URL=./data/growthbase.sqlite

PORT=3001

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional: Next.js `/api/demo-purchase` target when it should differ from NEXT_PUBLIC_API_BASE_URL (e.g. local web + remote API).

# DEMO_PURCHASE_API_BASE_URL=

# API (Railway / local): full URL of the public web app — used in purchase success JSON as verifyUrl (query receipt_id).

PUBLIC_WEB_APP_URL=https://growthbase-web.vercel.app

# Web (Vercel): canonical site + public live API (single hosted submission surface)

NEXT_PUBLIC_SITE_URL=https://growthbase-web.vercel.app

NEXT_PUBLIC_LIVE_API_BASE_URL=https://growthbase-production.up.railway.app

# Lane A (deterministic external success): optional stable base URL for fixture-mode API
# (deployed host or long-lived tunnel). Used by operators / agents; see docs/success-lane.md
# SUCCESS_LANE_API_BASE_URL=https://your-fixture-or-tunnel-host.example

NEXT_PUBLIC_REPO_DOC_BLOB_BASE=https://github.com/seiryu285/GrowthBase/blob/main

# Optional: expose the on-chain receipt anchor contract on /evidence and in docs links.
# Set these on Vercel only after you have a real deployed address to show reviewers.

# NEXT_PUBLIC_RECEIPT_ANCHOR_ADDRESS=0x...

# NEXT_PUBLIC_RECEIPT_ANCHOR_EXPLORER_URL=https://basescan.org/address/0x...

# Optional: override verify-bundle API base (defaults to LIVE API on Vercel)

# NEXT_PUBLIC_RECEIPT_VERIFY_API_BASE_URL=

# Legacy alias (still read by web):

# NEXT_PUBLIC_RECEIPT_VERIFY_API_URL=



X402_MODE=local

MARKET_DATA_MODE=live

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com

POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# Optional but recommended in strict live mode:
# narrow to liquid events to reduce PRE_PAYMENT_SERVICEABILITY_FAILED from one stale market blocking auto scans.
POLYMARKET_EVENT_SLUGS=

# Optional but recommended in strict live mode:
# narrow to liquid markets when you know the exact targets you want the live host to scan.
POLYMARKET_MARKET_SLUGS=

POLYMARKET_FETCH_TIMEOUT_MS=8000

# Live fail-closed freshness threshold. 15000ms is the repo default/recommended baseline for the public host.
POLYMARKET_MAX_BOOK_AGE_MS=15000

# Browser / CLI live demo defaults. Keep these aligned with the public host's narrowest practical live scan.
# `universe=auto` will still honor POLYMARKET_EVENT_SLUGS / POLYMARKET_MARKET_SLUGS on the API host.
GROWTHBASE_DEMO_UNIVERSE=auto
GROWTHBASE_DEMO_SIDE_POLICY=BOTH
GROWTHBASE_DEMO_REQUESTED_NOTIONAL_USD=100
GROWTHBASE_DEMO_MAX_CANDIDATES=10
GROWTHBASE_DEMO_RISK_MODE=standard
GROWTHBASE_DEMO_MAX_BOOK_AGE_MS=15000

X402_NETWORK=eip155:8453

X402_PRICE_ATOMIC=50000

X402_PAY_TO=0x0000000000000000000000000000000000000000

X402_FACILITATOR_URL=https://x402.org/facilitator

# Optional: enable fire-and-forget on-chain anchoring during receipt writes.

# ANCHOR_PRIVATE_KEY=0x...

# RECEIPT_ANCHOR_ADDRESS=0x...



AGENT_REGISTRY=eip155:8453:0x0000000000000000000000000000000000000000

AGENT_ID=demo-growthbase-agent

AGENT_URI=http://localhost:3001/.well-known/agent-registration.json

AGENT_WALLET=0x0000000000000000000000000000000000000000



SELLER_WALLET=0x0000000000000000000000000000000000000000

SELLER_IMAGE=https://placehold.co/600x600/png



NODE_ENV=development

