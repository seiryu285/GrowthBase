{
  "name": "growthbase",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "type": "module",
  "scripts": {
    "dev:api": "pnpm --filter @growthbase/api dev",
    "dev:web": "pnpm --filter @growthbase/web dev",
    "demo": "pnpm --filter @growthbase/agent-demo demo",
    "proof:oneshot": "pnpm --filter @growthbase/agent-demo proof:oneshot",
    "db:generate": "pnpm --filter @growthbase/db db:generate",
    "db:migrate": "pnpm --filter @growthbase/db db:migrate",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.44.6"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@growthbase/artifacts": "workspace:*",
    "@growthbase/core": "workspace:*",
    "@growthbase/db": "workspace:*",
    "@growthbase/growth": "workspace:*",
    "@growthbase/hidden-edge": "workspace:*",
    "@growthbase/identity": "workspace:*",
    "@growthbase/policy": "workspace:*",
    "@growthbase/receipt": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.2",
    "@x402/evm": "^2.7.0",
    "@x402/fetch": "^2.7.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "0.44.6",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "viem": "^2.28.0",
    "vitest": "^3.2.4"
  }
}
